    "validator.asleepAfterAwake" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Fell asleep\" must be earlier than \"Woke up\""
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「眠った」は「目覚めた」より前である必要があります"
          }
        }
      }
    },
    "validator.asleepBeforeBedIn" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Fell asleep\" must be at or after \"Got in bed\""
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「眠った」は「布団に入った」以降である必要があります"
          }
        }
      }
    },
    "validator.asleepBeforeBedIn.withTime" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Asleep time must be at or after bedtime (%@)"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "入眠時刻は入床時刻（%@）以降にしてください"
          }
        }
      }
    },
    "validator.awakeAfterBedOut" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Woke up\" must be at or before \"Got out of bed\""
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「目覚めた」は「布団から出た」以前である必要があります"
          }
        }
      }
    },
    "validator.awakeAfterBedOut.withTime" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wake time must be at or before wake-up (%@)"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "覚醒時刻は起床時刻（%@)以前にしてください"
          }
        }
      }
    },
    "validator.bedWindowInverted" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Got in bed\" must be earlier than \"Got out of bed\""
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「布団に入った」は「布団から出た」より前である必要があります"
          }
        }
      }
    },
    "validator.wakeEventInverted" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Awakening end must be after start"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "中途覚醒の終了時刻は開始時刻より後である必要があります"
          }
        }
      }
    },
    "validator.wakeEventOutOfBounds" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mid-sleep awakening must fall within the bed window"
